{
  "type": "module",
  "name": "@kosmojs/hono-generator",
  "version": "0.1.2",
  "author": "Slee Woo",
  "license": "MIT",
  "files": [
    "pkg/*"
  ],
  "imports": {
    "#templates/*": "./src/templates/*"
  },
  "exports": {
    ".": {
      "types": "./pkg/index.d.ts",
      "default": "./pkg/index.js"
    }
  },
  "scripts": {
    "build": "wsbuild src/index.ts",
    "test": "vitest --root ../.. --project generators/hono-generator"
  },
  "dependencies": {
    "@kosmojs/core": "workspace:^",
    "@kosmojs/lib": "workspace:^",
    "crc": "^4.3.2"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.0",
    "hono": "^4.12.15",
    "path-to-regexp": "^8.4.2"
  }
}
