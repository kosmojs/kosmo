{
  "type": "module",
  "name": "@kosmojs/typebox-generator",
  "version": "0.1.0",
  "cacheVersion": "1",
  "author": "Slee Woo",
  "license": "MIT",
  "files": [
    "pkg/*"
  ],
  "imports": {
    "#templates/*": "./src/templates/*"
  },
  "exports": {
    ".": {
      "types": "./pkg/index.d.ts",
      "default": "./pkg/index.js"
    }
  },
  "scripts": {
    "build": "wsbuild src/index.ts",
    "pretest": "pnpm run build",
    "test": "vitest --root ../.. --project generators/typebox-generator"
  },
  "devDependencies": {
    "@kosmojs/core": "workspace:^",
    "@kosmojs/lib": "workspace:^",
    "@kosmojs/core-generator": "workspace:^",
    "@kosmojs/koa-generator": "workspace:^",
    "typebox": "^1.1.34"
  }
}
