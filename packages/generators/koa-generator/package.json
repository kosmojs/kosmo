{
  "type": "module",
  "name": "@kosmojs/koa-generator",
  "version": "0.0.27",
  "author": "Slee Woo",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "pkg/*"
  ],
  "imports": {
    "#templates/*": "./src/templates/*"
  },
  "exports": {
    ".": {
      "types": "./pkg/index.d.ts",
      "default": "./pkg/index.js"
    },
    "./lib": {
      "types": "./pkg/lib.d.ts",
      "default": "./pkg/lib.js"
    }
  },
  "scripts": {
    "build": "esbuilder src/index.ts src/lib.ts",
    "test": "vitest --root ../../.. --project generators/koa-generator"
  },
  "dependencies": {
    "@kosmojs/lib": "workspace:^",
    "crc": "^4.3.2",
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@koa/router": "^15.4.0",
    "@kosmojs/core": "workspace:^",
    "@types/formidable": "^3.5.0",
    "@types/koa": "^3.0.2",
    "@types/koa-compose": "^3.2.9",
    "@types/picomatch": "^4.0.3",
    "cookie": "^1.1.1",
    "formidable": "^3.5.4",
    "koa": "^3.2.0",
    "koa-compose": "^4.1.0",
    "light-my-request": "^6.6.0",
    "path-to-regexp": "^8.4.2",
    "raw-body": "^3.0.2"
  }
}
