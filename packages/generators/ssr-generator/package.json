{
  "type": "module",
  "name": "@kosmojs/ssr-generator",
  "version": "0.0.27",
  "author": "Slee Woo",
  "license": "MIT",
  "files": [
    "pkg/*"
  ],
  "imports": {
    "#templates/*": "./src/templates/*"
  },
  "exports": {
    ".": {
      "types": "./pkg/index.d.ts",
      "default": "./pkg/index.js"
    }
  },
  "scripts": {
    "build": "esbuilder src/index.ts"
  },
  "dependencies": {
    "@kosmojs/lib": "workspace:^"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.0",
    "@kosmojs/core": "workspace:^",
    "hono": "^4.12.14",
    "tinyglobby": "^0.2.16"
  }
}
