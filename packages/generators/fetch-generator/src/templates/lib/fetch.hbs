{{#each routes}}
import {{id}} from "{{ createImport "libApi" name "fetch" }}";
{{/each}}

export { ValidationError } from "@kosmojs/core/errors";

export type ResponseT = {
{{#each routes}}
  "{{name}}": import("{{ createImport "libApi" name "fetch" }}").ResponseT;
{{/each}}
}

export default {
{{#each routes}}  "{{name}}": {{id}},
{{#each alias }}  "{{this}}": {{../id}},
{{/each}}
{{/each}}
}
