{{#each routes}}
import * as {{id}} from "{{ createImport "libApi" name "fetch" }}";
{{/each}}

export { ValidationError } from "@kosmojs/api/errors";

export type ResponseT = {
{{#each routes}}  "{{name}}": {{id}}.ResponseT;
{{/each}}
}

export default {
{{#each routes}}  "{{name}}": {{id}},
{{#each alias }}  "{{this}}": {{../id}},
{{/each}}
{{/each}}
}
