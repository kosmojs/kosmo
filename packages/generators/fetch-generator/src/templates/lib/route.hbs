import fetchFactory, {
  join,
  stringify,
  payloadResolver,
} from "@kosmojs/core/fetch";

import { baseurl, apiurl } from "{{ createImport "config" }}";
import { apiRouteMap } from "{{ createImport "libCore" }}";

import {
  type MaybeWrapped,
  unwrap,
} from "{{ createImport "lib" "unwrap" }}";

{{#each validationTypes}}
import type { {{id}} } from "./types";
{{/each}}

import { validationSchemas } from "./schemas";

export { ValidationError } from "@kosmojs/core/errors";

export { validationSchemas };

export type ParamsT = [
  {{serializeParamsTupleElements route}}
];

{{#each payloadTypes}}
export type {{name}} = {
  {{#each types}}{{method}}: {{id}};
  {{/each}}
}
{{/each}}

export type ResponseT = {
  {{#each responseTypes}}
  {{method}}: {{#each types}}{{#unless @first}}|{{/unless}} {{id}}{{/each}};
  {{/each}}
}

const {
  paramsMapper,
  parametrize,
  path,
  href,
} = apiRouteMap["{{route.name}}"];

const fetchApi = fetchFactory(join(baseurl, apiurl), { stringify });

{{#each routeMethods}}
export const {{method}} = (
  _params{{#if ../route.optionalParams}}?{{/if}}: MaybeWrapped<ParamsT>,
  _payload?: {
    {{#each ../payloadTargets}}
    {{#if payloadType}}
    {{target}}: {{payloadType.name}} extends { {{../method}}: unknown }
      ? MaybeWrapped<{{payloadType.name}}["{{../method}}"]>
      : unknown,
    {{else}}
    {{target}}?: unknown;
    {{/if}}
    {{/each}}
  },
  opt?: {
    unwrap?: <T>(data: MaybeWrapped<T>) => T;
  },
): Promise<
  {{#if responseType}}
  ResponseT["{{method}}"]
  {{else}}
  unknown
  {{/if}}
> => {
  const [params, payload] = [_params, _payload].map((data) => {
    return typeof opt?.unwrap === "function" ? opt.unwrap(data) : unwrap(data);
  })
  if (validationSchemas.params) {
    validationSchemas.params.validate(paramsMapper(params as never));
  }
  {{#each ../payloadTypes}}
  if (validationSchemas.{{target}}?.{{../method}}) {
    validationSchemas.{{target}}.{{../method}}.validate(
      payloadResolver(payload, "{{target}}")
    );
  }
  {{/each}}
  return fetchApi.{{method}}(parametrize(params as never), payload as never);
};
{{/each}}

export default {
  {{#each routeMethods}}
  {{method}},
  {{/each}}
  path,
  href,
  {{#if runtimeValidation}}
  validationSchemas,
  {{/if}}
};
