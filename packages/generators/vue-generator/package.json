{
  "type": "module",
  "name": "@kosmojs/vue-generator",
  "version": "0.0.25",
  "author": "Slee Woo",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "pkg/*"
  ],
