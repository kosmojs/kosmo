    "build": "esbuilder src/index.ts",
    "test": "vitest --root ../../.. --project generators/vue-generator"
  },
  "dependencies": {
    "@kosmojs/lib": "workspace:^",
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@kosmojs/fetch": "workspace:^",
    "@types/picomatch": "^4.0.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "path-to-regexp": "^8.3.0",
    "vite": "^8.0.2",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "peerDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  }
}
