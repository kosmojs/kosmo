import { clientRenderFactory } from "@kosmojs/core/generators";

{{#each pageEntries}}
const {{id}} = () => import("{{ createImport "pages" file }}");
{{/each}}

const NotFound = () => import("{{ createImport "pages" "404.vue" }}");

export const createRoutes = () => {
  return [
    {{#each nestedRoutes}}{{> routePartial}},
    {{/each}}
    // catch-all 404 - always last
    {
      path: "/:catchAll(.*)*",
      name: "NotFound",
      component: NotFound,
    },
  ];
}

export default clientRenderFactory();
