import type { JSX, ParentComponent } from "solid-js";
import type { RouteDefinition } from "@solidjs/router";
import type { RouterFactory } from "@kosmojs/core";

import { pagePathFactory } from "./solid";

export type LinkProps ={{#unless indexRoutes.length}} never{{/unless}}
  {{#each indexRoutes}}
  | [ "{{name}}", {{createParamsLiteral params}} ]
  {{/each}};

export type RouteName ={{#unless indexRoutes.length}} never{{/unless}}
  {{#each indexRoutes}}
  | "{{name}}"
  {{/each}};

export const pageMap = {
  {{#each indexRoutes}}
  "{{name}}": pagePathFactory<[ {{createParamsLiteral params}} ]>(
    {{serializeRoute .}},
  ),
  {{/each}}
}

export const routerFactory: RouterFactory<{
  router: JSX.Element;
  route: RouteDefinition,
  app: ParentComponent,
}> = (factory) => factory as never;
