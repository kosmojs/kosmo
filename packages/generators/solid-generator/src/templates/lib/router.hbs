import type { JSX } from "solid-js";
import type { RouteDefinition } from "@solidjs/router";
import { createPageLink, createRouterFactory } from "@kosmojs/core/generators";

import { baseurl } from "{{ createImport 'config' }}";

export type LinkProps ={{#unless indexRoutes.length}} never{{/unless}}
  {{#each indexRoutes}}
  | [ "{{name}}", {{serializeParamsTupleElements .}} ]
  {{/each}};

export const linkMap = {
  {{#each indexRoutes}}
  "{{name}}": createPageLink<[
    {{serializeParamsTupleElements .}}
  ]>({{pageLinkBase .}}, { baseurl }),
  {{/each}}
};

export default createRouterFactory<RouteDefinition, JSX.Element>();
