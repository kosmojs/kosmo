import { lazy } from "solid-js";
import { clientRenderFactory } from "@kosmojs/core/generators";

import { loaderFactory } from "../solid";

{{#each pageEntries}}
const {{id}}_component = lazy(() => import("{{ createImport "pages" file }}"));
const {{id}}_loader = () => import("{{ createImport "pages" file }}");
{{/each}}

const NotFound = lazy(() => import("{{ createImport "pages" "404.tsx" }}"));

export const createRoutes = (opt?: { withPreload?: boolean }) => {
  const maybeLoader = loaderFactory(opt);
  return [
    {{#each nestedRoutes}}{{> routePartial}},
    {{/each}}
    // catch-all 404 - always last
    {
      path: "*",
      component: NotFound,
    },
  ];
}

export default clientRenderFactory();
