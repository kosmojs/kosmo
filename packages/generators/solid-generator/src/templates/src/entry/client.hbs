import { hydrate, render } from "solid-js/web";

import { renderFactory, createRoutes } from "{{ createImport "libEntry" "client" }}";
import app from "{{ createImport "src" "App" }}";
import routerFactory from "{{ createImport "src" "router" }}";

const root = document.getElementById("app");

if (root) {
  const routes = createRoutes({ withPreload: true });
  const { clientRouter } = routerFactory(routes);
  renderFactory(() => {
    return {
      async clientRender() {
        const router = await clientRouter({ app });
        render(() => router, root);
      },
      async serverRender() {
        const router = await clientRouter({ app });
        hydrate(() => router, root)
      },
    }
  });
} else {
  console.error("❗Root element not found!");
}
