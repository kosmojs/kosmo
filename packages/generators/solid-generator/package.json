{
  "type": "module",
  "name": "@kosmojs/solid-generator",
  "version": "0.1.0",
  "author": "Slee Woo",
  "license": "MIT",
  "files": [
    "pkg/*"
  ],
  "imports": {
    "#templates/*": "./src/templates/*"
  },
  "exports": {
    ".": {
      "types": "./pkg/index.d.ts",
      "default": "./pkg/index.js"
    }
  },
  "scripts": {
    "build": "esbuilder src/index.ts",
    "test": "vitest --root ../../.. --project generators/solid-generator"
  },
  "dependencies": {
    "@kosmojs/core": "workspace:^",
    "@kosmojs/lib": "workspace:^"
  },
  "devDependencies": {
    "@solidjs/router": "^0.16.1",
    "path-to-regexp": "^8.4.2",
    "solid-js": "^1.9.12",
    "vite-plugin-solid": "^2.11.12"
  }
}
