{
  "type": "module",
  "name": "@kosmojs/dev",
  "version": "0.0.25",
  "cacheVersion": "001",
  "author": "Slee Woo",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "pkg/*"
  ],
  "exports": {
    ".": {
      "types": "./pkg/index.d.ts",
      "default": "./pkg/index.js"
    },
    "./chassis": {
      "types": "./pkg/chassis.d.ts",
      "default": "./pkg/chassis.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "esbuilder src/index.ts src/chassis.ts",
    "test": "vitest --root ../../.. --project core/dev"
  },
  "dependencies": {
    "@kosmojs/fetch-generator": "workspace:^",
    "@kosmojs/hono-generator": "workspace:^",
    "@kosmojs/koa-generator": "workspace:^",
    "@kosmojs/lib": "workspace:^",
    "@kosmojs/openapi-generator": "workspace:^",
    "@kosmojs/react-generator": "workspace:^",
    "@kosmojs/solid-generator": "workspace:^",
    "@kosmojs/ssr-generator": "workspace:^",
    "@kosmojs/typebox-generator": "workspace:^",
    "@kosmojs/vue-generator": "workspace:^",
    "crc": "^4.3.2"
  },
  "devDependencies": {
    "@kosmojs/api": "workspace:^",
    "vite": "^8.0.2"
  }
}
