{
  "type": "module",
  "name": "@kosmojs/core",
  "version": "0.0.26",
  "author": "Slee Woo",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "pkg/*"
  ],
  "exports": {
    ".": {
      "types": "./pkg/index.d.ts",
      "default": "./pkg/index.js"
    },
    "./api": {
      "types": "./pkg/api/index.d.ts",
      "default": "./pkg/api/index.js"
    },
    "./fetch": {
      "types": "./pkg/fetch/index.d.ts",
      "default": "./pkg/fetch/index.js"
    },
    "./errors": {
      "types": "./pkg/errors/index.d.ts",
      "default": "./pkg/errors/index.js"
    }
  },
  "scripts": {
    "build": "esbuilder src/index.ts src/api/index.ts src/fetch/index.ts src/errors/index.ts",
    "test": "vitest --root ../../.. --project core/core"
  },
  "dependencies": {
    "@koa/router": "^15.4.0",
    "formidable": "^3.5.4",
    "koa": "^3.1.2",
    "qs": "^6.15.0",
    "raw-body": "^3.0.2",
    "string-width": "^8.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/formidable": "^3.5.0",
    "@types/koa": "^3.0.2",
    "@types/koa-compose": "^3.2.9",
    "@types/node": "^25.5.0",
    "@types/picomatch": "^4.0.2",
    "@types/qs": "^6.15.0",
    "koa-compose": "^4.1.0",
    "tfusion": "^0.0.23"
  }
}
