{
  "type": "module",
  "name": "@kosmojs/core",
  "version": "0.1.7",
  "author": "Slee Woo",
  "license": "MIT",
  "files": [
    "pkg/*"
  ],
  "exports": {
    ".": {
      "types": "./pkg/index.d.ts",
      "default": "./pkg/index.js"
    },
    "./api": {
      "types": "./pkg/api/index.d.ts",
      "default": "./pkg/api/index.js"
    },
    "./fetch": {
      "types": "./pkg/fetch/index.d.ts",
      "default": "./pkg/fetch/index.js"
    },
    "./errors": {
      "types": "./pkg/errors/index.d.ts",
      "default": "./pkg/errors/index.js"
    },
    "./generators": {
      "types": "./pkg/generators/index.d.ts",
      "default": "./pkg/generators/index.js"
    }
  },
  "scripts": {
    "build": "wsbuild src/index.ts src/api/index.ts src/fetch/index.ts src/errors/index.ts src/generators/index.ts",
    "test": "vitest --root ../.. --project packages/core"
  },
  "dependencies": {
    "qs": "^6.15.1",
    "string-width": "^8.2.1"
  },
  "devDependencies": {
    "@types/qs": "^6.15.0",
    "hono": "^4.12.15",
    "msw": "^2.14.5",
    "path-to-regexp": "^8.4.2",
    "tfusion": "^0.0.24",
    "vite": "^8.0.10"
  }
}
