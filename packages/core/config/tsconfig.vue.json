{
  "extends": "./tsconfig.vite.json",
  "include": [
    "${configDir}",
    "${configDir}/../../lib/src/env.d.ts",
    "${configDir}/../../lib/src/vue.d.ts"
  ],
  "compilerOptions": {
    "jsxImportSource": "vue",
    "paths": {
      "~/*": [
        "${configDir}/../../*"
      ],
      "@/*": [
        "${configDir}/../../src/*"
      ],
      "_/*": [
        "${configDir}/../../lib/src/*"
      ]
    }
  }
}