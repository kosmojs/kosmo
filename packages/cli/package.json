{
  "type": "module",
  "name": "@kosmojs/cli",
  "version": "0.1.2",
  "author": "Slee Woo",
  "license": "MIT",
  "files": [
    "pkg/*"
  ],
  "bin": {
    "kosmo": "pkg/cli.js"
  },
  "imports": {
    "#templates/*": "./src/templates/*"
  },
  "exports": {
    ".": {
      "types": "./pkg/index.d.ts",
      "default": "./pkg/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "wsbuild src/cli.ts src/index.ts",
    "postbuild": "rsync -av --delete src/templates/ pkg/assets/templates",
    "test": "vitest --root ../.. --project packages/cli"
  },
  "dependencies": {
    "jiti": "^2.6.1",
    "prompts": "^2.4.2",
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@kosmojs/core": "workspace:^",
    "@kosmojs/dev": "workspace:^",
    "@kosmojs/lib": "workspace:^",
    "@types/node": "^25.6.0",
    "@types/prompts": "^2.4.9",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
