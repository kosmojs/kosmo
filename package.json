{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "download"
    }
  },
  "pnpm": {
    "requiredScripts": [
      "build"
    ],
    "onlyBuiltDependencies": [
      "esbuild",
      "msw"
    ]
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "test": "vitest run",
    "prepub": "./scripts/publish/prepare",
    "pub": "changeset publish",
    "pub:tags": "git push --follow-tags"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@changesets/cli": "^2.31.0",
    "@hono/node-server": "^2.0.0",
    "@kosmojs/cli": "workspace:^",
    "@kosmojs/core": "workspace:^",
    "@kosmojs/dev": "workspace:^",
    "@kosmojs/lib": "workspace:^",
    "@types/bun": "^1.3.12",
    "@types/deno": "^2.5.0",
    "@types/node": "^25.6.0",
    "cheerio": "^1.2.0",
    "crc": "^4.3.2",
    "esbuild": "^0.28.0",
    "esbuilder": "link:esbuilder",
    "got": "^15.0.3",
    "hono": "^4.12.14",
    "jiti": "^2.6.1",
    "msw": "^2.13.4",
    "ora": "^9.3.0",
    "path-to-regexp": "^8.4.2",
    "playwright": "^1.59.1",
    "resolve-tspaths": "^0.8.23",
    "rimraf": "^6.1.3",
    "tinyglobby": "^0.2.16",
    "tsconfig": "link:tsconfig",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "workspace-root": "^3.3.1"
  }
}
