{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "download"
    }
  },
  "pnpm": {
    "requiredScripts": [
      "build"
    ],
    "onlyBuiltDependencies": [
      "msw"
    ]
  },
  "scripts": {
    "prebuild": "pnpm -F *-generator run build",
    "build": "pnpm -F core -F lib -F dev -F cli -F create-kosmo --workspace-concurrency=1 run build",
    "preinstall": "npx only-allow pnpm",
    "test": "vitest run",
    "test:unit": "vitest run --project=packages/* --project=generators/*",
    "test:integration": "vitest run --project=integration:*",
    "test:integration:api": "vitest run --project=integration:api",
    "test:integration:csr": "vitest run --project=integration:csr",
    "test:integration:ssr": "vitest run --project=integration:ssr",
    "prepub": "./scripts/publish/prepare",
    "pub": "changeset publish",
    "pub:tags": "git push --follow-tags"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@changesets/cli": "^2.31.0",
    "@hono/node-server": "^2.0.0",
    "@kosmojs/cli": "workspace:^",
    "@kosmojs/core": "workspace:^",
    "@kosmojs/core-generator": "workspace:^",
    "@kosmojs/dev": "workspace:^",
    "@kosmojs/fetch-generator": "workspace:^",
    "@kosmojs/hono-generator": "workspace:^",
    "@kosmojs/koa-generator": "workspace:^",
    "@kosmojs/lib": "workspace:^",
    "@kosmojs/mdx-generator": "workspace:^",
    "@kosmojs/openapi-generator": "workspace:^",
    "@kosmojs/react-generator": "workspace:^",
    "@kosmojs/solid-generator": "workspace:^",
    "@kosmojs/ssg-generator": "workspace:^",
    "@kosmojs/ssr-generator": "workspace:^",
    "@kosmojs/typebox-generator": "workspace:^",
    "@kosmojs/vue-generator": "workspace:^",
    "@mdx-js/rollup": "^3.1.1",
    "@topcli/spinner": "^4.2.1",
    "@types/bun": "^1.3.13",
    "@types/deno": "^2.5.0",
    "@types/node": "^25.6.0",
    "cheerio": "^1.2.0",
    "crc": "^4.3.2",
    "got": "^15.0.3",
    "handlebars": "^4.7.9",
    "hono": "^4.12.14",
    "jiti": "^2.6.1",
    "mime-types": "^3.0.2",
    "msw": "^2.13.5",
    "path-to-regexp": "^8.4.2",
    "picomatch": "^4.0.4",
    "playwright": "^1.59.1",
    "resolve-tspaths": "^0.8.23",
    "tfusion": "^0.0.24",
    "tinyglobby": "^0.2.16",
    "ts-morph": "^28.0.0",
    "tsconfig": "link:tsconfig",
    "typebox": "^1.1.31",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "workspace-root": "^3.3.1",
    "wsbuild": "link:wsbuild",
    "yaml": "^2.8.3"
  }
}
