{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "download"
    }
  },
  "pnpm": {
    "requiredScripts": [
      "build"
    ],
    "onlyBuiltDependencies": [
      "msw"
    ]
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "test": "vitest run",
    "test:unit": "vitest run --project=packages/* --project=generators/*",
    "test:unit:generators": "vitest run --project=generators/*",
    "test:unit:packages": "vitest run --project=packages/*",
    "test:integration": "vitest run --project=integration:*",
    "test:integration:api": "vitest run --project=integration:api",
    "test:integration:csr": "vitest run --project=integration:csr",
    "test:integration:ssr": "vitest run --project=integration:ssr",
    "test:integration:cli": "vitest run --project=integration:cli",
    "prepub": "./scripts/publish/prepare",
    "pub": "changeset publish",
    "pub:tags": "git push --follow-tags"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.13",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.13",
    "@types/deno": "^2.5.0",
    "@types/node": "^25.6.0",
    "resolve-tspaths": "^0.8.23",
    "tsconfig": "link:tsconfig",
    "vitest": "^4.1.5",
    "wsbuild": "link:wsbuild"
  },
  "devDependencies": {}
}
