{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",

  "files": {
    "includes": [
      "vitest.config.js",
      "plugins/*",
      "wsbuild/*",
      "docs/**/*",
      "test/**/*",
      "{packages,generators}/*/{src,test}/**/*.ts",
      "!{packages,generators}/*/test/**/@{fixtures,snapshots}/**/*",
      "!test/**/@{fixtures,snapshots}/**/*"
    ]
  },

  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },

  "linter": {
    "enabled": true,
    "rules": {
      "performance": {
        "noAccumulatingSpread": "off"
      },
      "complexity": {
        "noBannedTypes": "off",
        "noUselessTernary": "off",
        "useLiteralKeys": "off"
      },
      "correctness": {
        "noUnusedVariables": {
          "level": "info",
          "options": {
            "ignoreRestSiblings": true
          }
        }
      },
      "style": {
        "useFilenamingConvention": "off"
      },
      "suspicious": {
        "noEmptyInterface": "off",
        "noConfusingVoidType": "off",
        "noConsole": {
          "level": "info",
          "options": {
            "allow": ["assert", "error", "info", "warn"]
          }
        }
      }
    }
  },

  "overrides": [
    {
      "includes": [
        "{packages,generators}/*/src/templates/src/**/*",
        "{packages,generators}/*/**/env.d.ts"
      ],
      "formatter": {
        "enabled": false
      },
      "assist": {
        "enabled": false
      }
    },
    {
      "includes": [
        "**/test/**/*.ts",
        "./{packages,generators}/*/src/templates/**/*.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          },
          "correctness": {
            "noUnusedFunctionParameters": "off",
            "noUnusedVariables": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/test/**/*.ts",
        "./wsbuild/**/*",
        "./{packages,generators}/*/src/templates/**/*.ts",
        "./packages/cli/src/**/*.ts",
        "./packages/create/**/*.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ],

  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              [":NODE:", ":BUN:"],
              ":BLANK_LINE:",
              [
                ":PACKAGE:",
                ":PACKAGE_WITH_PROTOCOL:",
                "!@kosmojs/**",
                "!@src/**",
                "!@test/**"
              ],
              ":BLANK_LINE:",

              [
                ":PACKAGE:",
                ":PACKAGE_WITH_PROTOCOL:",
                "@kosmojs/**",
                "!@kosmojs/**/*-generator",
                "!@src/**",
                "!@test/**"
              ],
              ":BLANK_LINE:",

              [
                ":PACKAGE:",
                ":PACKAGE_WITH_PROTOCOL:",
                "@kosmojs/**/*-generator",
                "!@src/**",
                "!@test/**"
              ],
              ":BLANK_LINE:",

              [":URL:"],
              ":BLANK_LINE:",

              [":ALIAS:"],
              ":BLANK_LINE:",

              [":PATH:", "!./templates/**"],
              ":BLANK_LINE:",

              [":PATH:"]
            ]
          }
        }
      }
    }
  }
}
